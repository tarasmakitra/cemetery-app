{
  "expo": {
    "name": "Cemetery Mapping",
    "slug": "cemetery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cemetery",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Потрібен доступ до GPS для визначення місцезнаходження могил.",
        "NSCameraUsageDescription": "Потрібен доступ до камери для фотографування могил.",
        "NSPhotoLibraryUsageDescription": "Потрібен доступ до галереї для вибору фотографій могил."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#212b36",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.anonymous.cemetery",
      "config": {
        "googleMaps": {}
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#212b36",
          "dark": {
            "backgroundColor": "#212b36"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Потрібен доступ до GPS для визначення місцезнаходження могил."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Потрібен доступ до галереї для вибору фотографій могил.",
          "cameraPermission": "Потрібен доступ до камери для фотографування могил."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
